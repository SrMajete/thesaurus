# Copy this file to .env and fill in the values you need.
# Env vars take precedence over .env values. Pydantic validates types
# at startup and fails fast on missing required fields.

# ── Provider ───────────────────────────────────────────────────────────────
# "anthropic" (direct API), "bedrock" (AWS), or "openai" (any OpenAI-compatible
# endpoint — Ollama, LM Studio, vLLM, OpenAI, Groq, Together, …). Default: anthropic
API_PROVIDER=anthropic

# Required when API_PROVIDER=anthropic (ignored on bedrock / openai)
ANTHROPIC_API_KEY=sk-ant-...

# Model ID. For anthropic: a model name (e.g. claude-sonnet-4-20250514).
# For bedrock: an ARN-based inference profile, e.g.
# arn:aws:bedrock:eu-central-1:123456789012:inference-profile/eu.anthropic.claude-sonnet-4-6
# For openai: whatever the endpoint expects (e.g. qwen2.5-coder:32b, gpt-4o).
MODEL=claude-sonnet-4-20250514

# ── AWS Bedrock (only when API_PROVIDER=bedrock) ───────────────────────────
# Use AWS_PROFILE (preferred) or the explicit access/secret/session triple.
#AWS_REGION=eu-central-1
#AWS_PROFILE=default
#AWS_ACCESS_KEY=
#AWS_SECRET_KEY=
#AWS_SESSION_TOKEN=

# ── OpenAI-compatible provider (only when API_PROVIDER=openai) ─────────────
# "openai" here is the *wire protocol*, not the company. Works with Ollama,
# LM Studio, vLLM, Groq, Together, DeepSeek, and real OpenAI — set the
# base URL to whatever endpoint you want.
#
# Ollama:    OPENAI_BASE_URL=http://localhost:11434/v1    OPENAI_API_KEY=ollama
# LM Studio: OPENAI_BASE_URL=http://localhost:1234/v1     OPENAI_API_KEY=lm-studio
# vLLM:      OPENAI_BASE_URL=http://localhost:8000/v1     OPENAI_API_KEY=token
# OpenAI:    OPENAI_BASE_URL=https://api.openai.com/v1    OPENAI_API_KEY=sk-...
# Groq:      OPENAI_BASE_URL=https://api.groq.com/openai/v1  OPENAI_API_KEY=gsk_...
#
# OPENAI_API_KEY must be non-empty (SDK requirement); local servers ignore it.
# Set OPENAI_MAX_CONTEXT_TOKENS to your model's real context window so context
# pruning triggers at the right threshold — the default 32768 matches common
# 32K-context local models; bump to 128000 for GPT-4o / Qwen-long / etc.
#
# Reliable models for the agent loop (tool_choice=required is demanding):
# Qwen 2.5 Coder 32B, Llama 3.3 70B, DeepSeek-V3, GPT-OSS-20B/120B, GPT-4o.
# Models under ~14B typically fail to produce valid tool calls.
#OPENAI_BASE_URL=http://localhost:11434/v1
#OPENAI_API_KEY=ollama
#OPENAI_MAX_CONTEXT_TOKENS=32768

# ── Confluence (optional — RAG search) ────────────────────────────────────
# All three are required for the search_confluence tool to register.
#CONFLUENCE_URL=https://your-domain.atlassian.net
#CONFLUENCE_EMAIL=your-email@company.com
#CONFLUENCE_API_KEY=your-api-token

# ── Agent ──────────────────────────────────────────────────────────────────
# Maximum agentic turns per user input before the loop bails. Default: 10
MAX_TURNS=10

# Prune old tool results when context tokens exceed this fraction of the
# model's max input tokens. Range 0.0–1.0. Default: 0.8 (prune at 80%)
PRUNE_CONTEXT_THRESHOLD=0.8
