# Copy this file to .env and fill in the values you need.
# Env vars take precedence over .env values. Pydantic validates types
# at startup and fails fast on missing required fields.

# ── Provider ───────────────────────────────────────────────────────────────
# "anthropic" (direct API) or "bedrock" (AWS). Default: anthropic
API_PROVIDER=anthropic

# Required when API_PROVIDER=anthropic (ignored on bedrock)
ANTHROPIC_API_KEY=sk-ant-...

# Model ID. For anthropic: a model name (e.g. claude-sonnet-4-20250514).
# For bedrock: an ARN-based inference profile, e.g.
# arn:aws:bedrock:eu-central-1:123456789012:inference-profile/eu.anthropic.claude-sonnet-4-6
MODEL=claude-sonnet-4-20250514

# ── AWS Bedrock (only when API_PROVIDER=bedrock) ───────────────────────────
# Use AWS_PROFILE (preferred) or the explicit access/secret/session triple.
#AWS_REGION=eu-central-1
#AWS_PROFILE=default
#AWS_ACCESS_KEY=
#AWS_SECRET_KEY=
#AWS_SESSION_TOKEN=

# ── Agent ──────────────────────────────────────────────────────────────────
# Maximum agentic turns per user input before the loop bails. Default: 10
MAX_TURNS=10

# ── Terminal UI ────────────────────────────────────────────────────────────
# "rich"    — Rich-library themed scroll-based REPL (default)
# "classic" — hand-rolled ANSI UI, no third-party TUI dep
# "tui"     — full-screen Textual TUI (fixed input, scrollable history,
#             mouse support, collapsible tool blocks, modal prompts).
#             Requires a real terminal (fails on piped stdin).
CLI_STYLE=rich

# ── Diagnostics ────────────────────────────────────────────────────────────
# Enable verbose DEBUG logging to logs/agent_debug_*.log. Default: false
DEBUG=false
